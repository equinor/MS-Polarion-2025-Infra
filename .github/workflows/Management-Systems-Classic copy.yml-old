      - name: 🔨 🔧🚽🚿 🏡Run PowerShell scripts to Install DotNet6-x64 on Azure VMs
        if: false
        uses: azure/powershell@v2
        with:
          azPSVersion: latest
          inlineScript: |
            pushd ./custom-script
            (get-ChildItem -filter *.ps1).name | Foreach-Object {
              $psType = @()
              if ($_ -like "*51*"){
                Write-Output "Runtime Version 5.1"
                $pstype = "PowerShell"
                $tempFileName = $_
                $trimmedName = $tempfileName.split(".")[0]
                  }
              }
              # Define the resource group name
              $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" # Replace with your resource group name
              $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }

              foreach ($VM in $vmList) {
                  # Define the script that creates the scheduled task
                  $ScriptBlock = {
                      # Check if the ScheduledTasks module is available
                      if (!(Get-Module -ListAvailable -Name ScheduledTasks)) {
                          Write-Output "The ScheduledTasks module is not available on this system."
                          return
                      }

                      # Define the base URI for .NET downloads
                      $DotNetBaseUri = "https://dotnet.microsoft.com/download/dotnet/6.0"

                      # Use Invoke-WebRequest to get the .NET download page content
                      $DotNetPage = Invoke-WebRequest -Uri $DotNetBaseUri -UseBasicParsing

                      # Use a regular expression to find the latest .NET 6 version number
                      $DotNet6Version = ($DotNetPage.Content | Select-String -Pattern 'dotnet-sdk-([0-9\.]+)-win-x64.exe' -AllMatches).Matches | ForEach-Object { $_.Groups[1].Value } | Sort-Object -Unique | Select-Object -Last 1

                      # Define the download URI based on the version
                      $DotNet6Uri = "https://download.microsoft.com/download/6/$DotNet6Version/dotnet-sdk-$DotNet6Version-win-x64.exe"

                      # Define the local path where you want to save the installer
                      $DownloadPath = "C:\Appl\dotnet6-win-x64.exe"

                      # Download the file and overwrite if it already exists
                      Invoke-WebRequest -Uri $DotNet6Uri -OutFile "C:\Appl\dotnet6-win-x64.exe" -UseBasicParsing

                      # Install .NET with silent and no restart options
                      Start-Process -FilePath "C:\Appl\dotnet6-win-x64.exe" -ArgumentList "/quiet", "/norestart" -NoNewWindow -Wait

                      # Create the scheduled task to run the script daily
                      $Action = New-ScheduledTaskAction -Execute 'powershell.exe' -Argument '-ExecutionPolicy Bypass -File "C:\Appl\dotnet6-win-x64.ps1"'
                      $Trigger = New-ScheduledTaskTrigger -Daily -At 6pm
                      $Settings = New-ScheduledTaskSettingsSet
                      $Principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -LogonType ServiceAccount
                      Register-ScheduledTask -Action $Action -Trigger $Trigger -TaskName "UpdateDotNetSDK" -Description "Daily task to check for .NET updates" -Settings $Settings -Principal $Principal
                  }

                  Invoke-AzVMRunCommand -ResourceGroupName "s499-ms-polarion-${{ env.environmentName }}" -VMName $VM -ScriptString $scriptBlock -CommandId RunPowerShellScript
              }
            
            
                            
      
