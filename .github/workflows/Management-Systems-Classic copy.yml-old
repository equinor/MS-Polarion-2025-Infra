name: Management-Systems-Classic # have the same name in folder structure and yml file

on:
  schedule:
    # At 00:00 on Sunday (UTC)
    - cron: '0 0 * * 0'  
  push:
    branches:
      - main
    paths:
      - 'template-bundles/omnia-classic/Management-Systems-Classic/**'
      - 'Bicep/**'
      - 'Environments/**'
      - '.github/**'
      - 'DeploymentFiles/**'
      - '!Manual/**'
      - '!**/.md'

run-name: ${{ github.actor }} started deployment of MS Polarion - S499

permissions:
  id-token: write
  contents: read

defaults: 
  run:
    shell: pwsh

# Global Environment Information
env:
  TenantID: ${{ secrets.AZURE_TENANT_ID }} #Equinor Azure TenantID
  AppId: ${{ secrets.S499_AZURE_CLIENT_ID }}
  Subscription: ${{ secrets.S499_AZURE_SUBSCRIPTION_ID }} # Replace with desired your Azure subscription id in Equinor
  AppSecret: ${{ secrets.S499_AZURE_CLIENT_SECRET }}
  FKEYPW: ${{ secrets.S499_AZURE_FKEYPW }}
  SubscriptionPrefix: 'S499'
  ##AdminGroup: 'AZAPPL S498 - Owner' # Replace with your linux admin group, preferable a role/group in AccessIt or leave empty
  ModulesPath: './template-bundles/omnia-classic/'
  location: 'norwayeast' # Replace with desired location
  resourceGroupName: 'MS-POLARION'
  KeyVaultName: 'MS-POLARION-KV'
  
 
jobs:
  DEV:
    if: true
    runs-on: ubuntu-24.04
    environment: DEV # create this in Azure as an App Registration, need to be application developer in azure in order to create app registration(pim yourself to enable your role in order to create azure app)
    
    env:
      ModuleName: Management-Systems-Classic
      environmentName: DEV
      ACTIONS_STEP_DEBUG: true
      s499_Ms_Polarion_Iac_Deployment_NONPROD_DEV_Object_ID : "${{ secrets.S499_MS_POLARION_IAC_DEPLOYMENT_NONPROD_OBJECT_ID }}"

    steps:
      - name: 🤑💸Checkout parameter
        uses: actions/checkout@v3
      
      - name: Install Azure module to resolve Token issue
        uses: ./.github/actions/az-install
        with:
          version: 11.6.0          # This version of PS remediates the OIDC token expiry issue - #10249
        
      - name: 🥳 Connect to Azure
        uses: azure/login@v2
        with:
          client-id: ${{ secrets.AZURE_CLIENT_ID }}
          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}
          enable-AzPSSession: true

      - name: Azure PowerShell script
        uses: azure/powershell@v2
        with:
          azPSVersion: "latest"
          inlineScript: |
            Get-AzWebApp

      - name: "Get resource group with PowerShell action"
        uses: azure/powershell@v2
        with:
          inlineScript: |
            Write-Output "starting deployment step"
          azPSVersion: "latest"
          
      - name: Enable Azure CLI Diagnostics
        run: az configure --defaults logging.enable_log_file=yes

      - name: Install Azure CLI KeyVault extension
        run: |
          Install-Module -Name Microsoft.PowerShell.SecretManagement -Repository PSGallery -Force
          Install-Module Az.KeyVault -Repository PSGallery -Force
          Import-Module Microsoft.PowerShell.SecretManagement
          Import-Module Az.KeyVault
          $VaultParameters = @{  
            AZKVaultName = "${{env.resourceGroupName}}-KV2-${{ env.environmentName }}" 
            SubscriptionId = "${{ secrets.AZURE_SUBSCRIPTION_ID }}" 
          } 
          Register-SecretVault -Module Az.KeyVault -Name AzKV -VaultParameters $VaultParameters

      - name: ⚡⚡Installing modules
        shell: pwsh
        run: |
          Install-Module Az.Accounts -force -MaximumVersion 3.0.5
          Install-Module Az.Resources -force -MaximumVersion "7.6.0"
          Install-Module Az.Network -force -MaximumVersion "7.10.0"
          Install-Module Az.Compute -force -MaximumVersion "8.5.0"
          Install-Module -Name AzureAD -Force -AllowClobber
      
      - name: ⚡⚡Install AzCopy
        shell: bash
        run: |
          wget -O azcopy.tar.gz https://aka.ms/downloadazcopy-v10-linux
          tar -xf azcopy.tar.gz --strip-components=1
          sudo mv ./azcopy /usr/local/bin/
          azcopy --version

      - name: 	🔐🏠Deploying Azure resources BaseLine - ResourceGroup and Keyvault
        shell: pwsh
        run: |
          
        
        
          # Check for external IP address
          $runner = (Invoke-RestMethod -Uri https://ipinfo.io/json).ip
          Write-Output "Runner: $runner"
          $S499_MS_CLASSIC_OMNIA_OWNER = "${{ secrets.S499_MS_CLASSIC_OMNIA_OWNER }}"
          $location = "${{ env.location }}"
          $Deploy_iac_objectID = "${{ secrets.AZAPPL_S499_OWNER }}"
          $s499_MS_POLARION_IAC_DEPLOYMENT_NONPROD_DEV_OBJECT_ID = "${{secrets.S499_MS_POLARION_IAC_DEPLOYMENT_NONPROD_OBJECT_ID}}"

          New-AzSubscriptionDeployment -Name "Deploy-${{ env.environmentName }}-${{ github.actor }}" `
            -TemplateFile '${{ env.ModulesPath }}/${{ env.ModuleName }}/base.open.deploy.bicep' `
            -resourceGroupName "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" `
            -TemplateParameterFile '${{ env.ModulesPath }}/${{ env.ModuleName }}/${{ env.environmentName }}/1.base.open.parameters.polarion.DEV.json' `
            -tenantId '${{ secrets.AZURE_TENANT_ID }}' `
            -subscriptionId '${{ secrets.AZURE_SUBSCRIPTION_ID }}' `
            -subscriptionPrefix '${{ env.SubscriptionPrefix }}' `
            -AZAPPL_S499_OWNER '${{ secrets.AZAPPL_S499_OWNER }}' `
            -S499_MS_Classic_Omnia_Contributor '${{ secrets.S499_MS_Classic_Omnia_Contributor }}' `
            -S499_MS_CLASSIC_OMNIA_OWNER $S499_MS_CLASSIC_OMNIA_OWNER `
            -Deploy_iac_objectID $Deploy_iac_objectID `
            -location $location `
            -s499_MS_POLARION_IAC_DEPLOYMENT_NONPROD_DEV_OBJECT_ID '${{env.s499_Ms_Polarion_Iac_Deployment_NONPROD_DEV_Object_ID }}' `
            -runner $runner

      - name: Generate and set passwords to Keyvault with powershell
        run: |
        
          # Load the System.Web assembly
          Add-Type -AssemblyName System.Web

          # Get the current date/time in UTC+1
          $NorwayBaseTime = (Get-Date).ToUniversalTime().AddHours(1)
          
          # Calculate the expiry date (180 days from now)
          $expiry = $NorwayBaseTime.AddDays(180)
          
          # Define the names of your VMs
          $vm_names = "PLWS01-${{ env.environmentName }}", "PLWS02-${{ env.environmentName }}", "PLWS03-${{ env.environmentName }}", "PLWS04-${{ env.environmentName }}"
          
          # Loop over the VM names
          foreach ($vm_name in $vm_names) {
          # Get the secret from the Azure Key Vault
          $secret = Get-AzKeyVaultSecret -VaultName "${{ env.KeyVaultName }}2-${{ env.environmentName }}" -Name "${vm_name}"
      
          # Check if the secret is expired or null/blank
          if ($secret.Expires -lt $NorwayBaseTime -or $secret.SecretValueText -eq $null -or $secret.SecretValueText -eq "") {
            # Generate a new random password for the VM
            $vm_password = ConvertTo-SecureString -String (openssl rand -base64 32) -AsPlainText -Force
              
            # Set the new password in the Azure Key Vault with the calculated expiry date
            # This will create a new version of the secret
            # Set the contentType to "VM"
            Set-AzKeyVaultSecret -VaultName "${{ env.KeyVaultName }}2-${{ env.environmentName }}" -Name "${vm_name}" -SecretValue $vm_password -Expires $expiry -ContentType "VM"

            }
          }

          
      - name: 🔨⌛🔨⌛💻🏠Deploying Azure resources
        
        shell: pwsh
        run: |
            # pushd ./DeploymentFiles
            Write-Output "Now deploying MS POLARION ${{ env.environmentName }}"
            Write-Output "location: ${{ env.location }}"
        
            $passwords = @()
            $vmList = "${{ env.SubscriptionPrefix }}PLWS01-${{ env.environmentName }}", "${{ env.SubscriptionPrefix }}PLWS02-${{ env.environmentName }}", "${{ env.SubscriptionPrefix }}PLWS03-${{ env.environmentName }}", "${{ env.SubscriptionPrefix }}PLWS04-${{ env.environmentName }}"
            foreach ($vm in $vmList) {
              $password = openssl rand -base64 100 | tr -dc 'A-Za-z0-9!@#$%^&*()' | head -c 14 
              Write-Host "Generated adminPasswordsarray for $vm"
              $passwords += [PSCustomObject]@{
                Name = $vm
                Password = $password
              }
            }
            $adminPasswordsarray = $passwords | ForEach-Object { $_.Password }
            $adminPasswordsarray_json = $adminPasswordsarray | ConvertTo-Json

            $iac_objectid = "${{ secrets.S499_MS_CLASSIC_OMNIA_OWNER }}"            
            
           
            New-AzSubscriptionDeployment -Name "Deployment-${{ env.environmentName }}-${{ github.actor }}-$(get-random)" `
              -TemplateFile "${{ env.ModulesPath }}/${{ env.ModuleName }}/deploy.bicep" `
              -resourceGroupName "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" `
              -subscriptionId "${{ secrets.S499_AZURE_SUBSCRIPTION_ID }}" `
              -TemplateParameterFile "${{ env.ModulesPath }}/${{ env.ModuleName }}/${{ env.environmentName }}/2.deploy.parameters.polarion.${{ env.environmentName }}.json" `
              -location "${{ env.location }}" `
              -UserAssignedIdentitiesClient_ID "${{ secrets.USERASSIGNEDIDENTITIES_CLIENTID }}" `
              -tenantId "${{ secrets.AZURE_TENANT_ID }}" `
              -subscriptionPrefix '${{ env.SubscriptionPrefix }}' `
              -AZAPPL_S499_OWNER "${{ secrets.AZAPPL_S499_OWNER }}" `
              -S499_MS_Classic_Omnia_Contributor "${{ secrets.S499_MS_Classic_Omnia_Contributor }}" `
              -iac_clientid "${{ secrets.S499_AZURE_CLIENT_ID }}" `
              -adminPasswordsarray $adminPasswordsarray `
              -adminPasswordsarray_json $adminPasswordsarray_json 
               

              $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}"
              $backupresourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}-BACKUP"
              $resourceGroupNames = @($ResourceGroupName, $backupresourceGroupName)
      
              
              # $tags = @{
              #     Solution = "MS-Polarion"
              #     ContactPerson = "Tore Melberg, Michael Rainer Haag"
              #     Email = "torme@equinor.com, mhaag@equinor.com"
              #     CostAllocationCode = "107505"
              #     CostAllocationType = "AppId"
              #     Team = "Management Systems"
              #     Repository = "https://github.com/equinor/Polarion-infra"
              # }
  
              # foreach ($name in @($resourceGroupName, $backupresourceGroupName)) {
              #     $failedResources = @()
              #     $resources = Get-AzResource -ResourceGroupName $name
              #     foreach ($resource in $resources) {
              #       try {
              #         Set-AzResource -Tag $tags -ResourceId $resource.ResourceId -Force
              #         Write-Host "Tags set for resource: $($resource.Name) in the resource group '$name'."
              #       }
              #       catch {
              #         $failedResources += $resource
              #         Write-Host "::error::Failed to set tags for resource: $($resource.Name) with ResourceId: $($resource.ResourceId)"
              #       }
              #     }
  
              #     if ($failedResources.Count -gt 0) {
              #       Write-Host "::error::Some resources in resource group '$name' failed to update with tags. Check the job logs for more details."
              #       foreach ($resource in $failedResources) {
              #         Write-Host "$($resource.Name) - ResourceId: $($resource.ResourceId)"
              #       }
              #     }
              #     else {
              #       Write-Host "All resources in the resource group '$name' have been successfully tagged."
              #     }
              #   }
            
      - name: 👀📫👻 Get VM info and private IP addresses with type of allocation method
        uses: azure/powershell@v2
        with:
          azPSVersion: "latest"
          inlineScript: |  
            $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}"
            $vms = Get-AzVM -ResourceGroupName $resourceGroupName
            $nics = Get-AzNetworkInterface -ResourceGroupName $resourceGroupName | Where-Object VirtualMachine -NE $null
            $vmInfo = $vms | ForEach-Object {
                      $vm = $_
                      $nic = $nics | Where-Object { $_.VirtualMachine.Id -eq $vm.Id }
                      [PSCustomObject]@{
                          Name = $vm.Name
                          PrivateIpAddress = $nic.IpConfigurations[0].PrivateIpAddress
                          IpAllocationMethod = $ipAllocationMethod
                      }
                }
                $privateIpAddresses = $vmInfo | ForEach-Object { $_.PrivateIpAddress }
                Write-Output "privateIpAddresses: $privateIpAddresses"

                foreach ($info in $vmInfo) {
                  if ($info.IpAllocationMethod -eq "Static") {
                  Write-Output "The IP address for $($info.Name)-$($info.IpAllocationMethod) is static."
                    } else {
                    Write-Output "The IP address for $($info.Name)-$($info.IpAllocationMethod) is not static."
                    }
                  }
            
      - name: 🔨📮📫✅ Set IP allocation method to Static and print private IP addresses
        uses: azure/powershell@v2
        with:
          azPSVersion: "latest"
          inlineScript: |
            $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}"
            $vms = Get-AzVM -ResourceGroupName $resourceGroupName
            $nics = Get-AzNetworkInterface -ResourceGroupName $resourceGroupName | Where-Object { $_.VirtualMachine -ne $null }
            $vmInfo = $vms | ForEach-Object {
            $vm = $_
            $nic = $nics | Where-Object { $_.VirtualMachine.Id -eq $vm.Id }
            # Set the IP allocation method to static
            $nic.IpConfigurations[0].PrivateIpAllocationMethod = "Static"
            # Apply the changes to the NIC
            $nic | Set-AzNetworkInterface
            [PSCustomObject]@{
              Name = $vm.Name
              PrivateIpAddress = $nic.IpConfigurations[0].PrivateIpAddress
              IpAllocationMethod = $nic.IpConfigurations[0].PrivateIpAllocationMethod
              }
            }
            # Print the output
            $vmInfo | Format-Table -AutoSize

      - name: Run PowerShell script set laps
        if: false
        uses: azure/powershell@v2
        with:
          azPSVersion: "latest"
          inlineScript: |
            $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" # Replace with your resource group name
            $lapsUrl = "https://ans.equinor.com/Laps" # Replace with your LAPS service URL
            $keyVaultName = "${{env.resourceGroupName}}-KV-${{ env.environmentName }}" # Replace with your Key Vault name
            
            # Get the list of VMs in the resource group
            $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }

            if ($vmList -ne $null -and $vmList.Count -gt 0) {
              foreach ($vm in $vmList) {
            
            # If the VM exists, reset its password
            $response = Invoke-RestMethod -Uri "$lapsUrl/api/password/$vm" -Method Post
            Write-Host "Reset password for $vm. Response: $response"
                
            # Convert the password to a secure string
            $securePassword = ConvertTo-SecureString -String $password -AsPlainText -Force

            # Upload the password to Azure Key Vault
                  Set-AzKeyVaultSecret -VaultName $keyVaultName -Name "$vm-password" -SecretValue $securePassword
                }
              } else {
                Write-Host "No VMs found in resource group $resourceGroupName"
              }

      - name: 🔨🔩🏠Configure Windows Server on Azure VM
        if: false
        uses: azure/powershell@v2
        with:
          azPSVersion: "latest"
          inlineScript: |
            pushd ./custom-script
              (get-ChildItem -filter *.ps1).name | Foreach-Object {
                $psType = @()
                if ($_ -like "*51*"){
                  Write-Output "Runtime Version 5.1"
                  $pstype = "PowerShell"
                  $tempFileName = $_
                  $trimmedName = $tempfileName.split(".")[0]
                    }
                }
            $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" # Replace with your resource group name
            $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }
      
            
      
            # Loop over each VM and run the script
            foreach ($VM in $vmList) {
              Invoke-AzVMRunCommand -ResourceGroupName $resourceGroupName -Name $VM -ScriptPath ./Add-WindowsServerDefaults.ps1 -CommandId RunPowerShellScript
            }                        


      - name: 🔨 🔧🚽🚿 🏡Run PowerShell scripts to Install DotNet6-x64 on Azure VMs
        
        uses: azure/powershell@v2
        with:
          azPSVersion: latest
          inlineScript: |
            pushd ./custom-script
            (get-ChildItem -filter *.ps1).name | Foreach-Object {
              $psType = @()
              if ($_ -like "*51*"){
                Write-Output "Runtime Version 5.1"
                $pstype = "PowerShell"
                $tempFileName = $_
                $trimmedName = $tempfileName.split(".")[0]
                  }
              }
              # Define the resource group name
              $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" # Replace with your resource group name
              $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }

              foreach ($VM in $vmList) {
                  # Define the script that creates the scheduled task
                  $ScriptBlock = {
                      # Check if the ScheduledTasks module is available
                      if (!(Get-Module -ListAvailable -Name ScheduledTasks)) {
                          Write-Output "The ScheduledTasks module is not available on this system."
                          return
                      }

                      # Define the base URI for .NET downloads
                      $DotNetBaseUri = "https://dotnet.microsoft.com/download/dotnet/6.0"

                      # Use Invoke-WebRequest to get the .NET download page content
                      $DotNetPage = Invoke-WebRequest -Uri $DotNetBaseUri -UseBasicParsing

                      # Use a regular expression to find the latest .NET 6 version number
                      $DotNet6Version = ($DotNetPage.Content | Select-String -Pattern 'dotnet-sdk-([0-9\.]+)-win-x64.exe' -AllMatches).Matches | ForEach-Object { $_.Groups[1].Value } | Sort-Object -Unique | Select-Object -Last 1

                      # Define the download URI based on the version
                      $DotNet6Uri = "https://download.microsoft.com/download/6/$DotNet6Version/dotnet-sdk-$DotNet6Version-win-x64.exe"

                      # Define the local path where you want to save the installer
                      $DownloadPath = "C:\Appl\dotnet6-win-x64.exe"

                      # Download the file and overwrite if it already exists
                      Invoke-WebRequest -Uri $DotNet6Uri -OutFile "C:\Appl\dotnet6-win-x64.exe" -UseBasicParsing

                      # Install .NET with silent and no restart options
                      Start-Process -FilePath "C:\Appl\dotnet6-win-x64.exe" -ArgumentList "/quiet", "/norestart" -NoNewWindow -Wait

                      # Create the scheduled task to run the script daily
                      $Action = New-ScheduledTaskAction -Execute 'powershell.exe' -Argument '-ExecutionPolicy Bypass -File "C:\Appl\dotnet6-win-x64.ps1"'
                      $Trigger = New-ScheduledTaskTrigger -Daily -At 6pm
                      $Settings = New-ScheduledTaskSettingsSet
                      $Principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -LogonType ServiceAccount
                      Register-ScheduledTask -Action $Action -Trigger $Trigger -TaskName "UpdateDotNetSDK" -Description "Daily task to check for .NET updates" -Settings $Settings -Principal $Principal
                  }

                  Invoke-AzVMRunCommand -ResourceGroupName "s499-ms-polarion-${{ env.environmentName }}" -VMName $VM -ScriptString $scriptBlock -CommandId RunPowerShellScript
              }
                
                
                                
          
      - name: Install VCRedist-x64 on Azure VMs
        if: false
        uses: azure/powershell@v2
        with:
          azPSVersion: latest
          inlineScript: |
            pushd ./custom-script
