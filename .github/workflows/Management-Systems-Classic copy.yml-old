      - name: 🔨🔐🏡Create Admin_SecurityGroups for vms
        if: true
        uses: azure/powershell@v2
        with:
            azPSVersion: latest
            inlineScript: |
              # Define headers for the REST method
              $headers = @{
                  "Accept" = "application/json"
              }

              # Define members for the JSON data
              $members = @("a_torme","a_awy","a_otras","a_johab","a_mhaag","A_ESAMD")

              # Get the resource group name
              $resourceGroupName = "${env:SubscriptionPrefix}-${env:resourceGroupName}-${env:environmentName}" # Replace with your resource group name

              # Get the list of VMs in the resource group
              $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }

              # Check if there are any VMs in the list
              if ($vmList.Count -eq 0) {
                  Write-Output "No VMs found in resource group $resourceGroupName"
                  exit 1
              }

              # Loop through each VM in the list
              foreach ($vmName in $vmList) {
                  # Create JSON data for each server
                  $jsonData = @{
                      "serverName" = $vmName
                      "members" = $members
                  } | ConvertTo-Json

                  $scriptBlock = @"
                  try {
                      # Invoke the REST method for each server
                      Invoke-RestMethod -Uri "https://ocn-adgroup.equinor.com/api/ServerAdGroup" -Method Post -Body $jsonData -ContentType "application/json" -Headers $headers
                  }
                  catch {
                      Write-Error "Failed to invoke REST method for server $vmName"
                      exit 1
                  }
              "@
                  # Run the script on the VM
                  Invoke-AzVMRunCommand -ResourceGroupName $resourceGroupName -VMName $vmName -CommandId 'RunPowerShellScript' -ScriptString $scriptBlock
              }
      
      - name: 👷🔨🔐🏡Add AdminUserGroup for Admin_SecurityGroups for vms
        if: false
        uses: azure/powershell@v2
        with:
            azPSVersion: latest
            inlineScript: |
              # Define the Object ID of the group you want to add
              $nestedGroupId = "80aaa1c7-b625-4ca7-a48e-fcbdfa5e95f6"
              
              # Define the names of the groups you want to add the nested group to
              $groupNames = @("Admin_${env:SubscriptionPrefix}PLWS01-${env:environmentName}", "Admin_${env:SubscriptionPrefix}PLWS02-${env:environmentName}", "Admin_${env:SubscriptionPrefix}PLWS03-${env:environmentName}", "Admin_${env:SubscriptionPrefix}PLWS04-${env:environmentName}")
              
              # Get the resource group name
              $resourceGroupName = "${env:SubscriptionPrefix}-${env:resourceGroupName}-${env:environmentName}" # Replace with your resource group name
              
              # Get the list of VMs in the resource group
              $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }
              
              # Check if there are any VMs in the list
              if ($vmList.Count -eq 0) {
                  Write-Output "No VMs found in resource group $resourceGroupName"
                  exit 1
              }
              
              # Loop through each VM in the list
              foreach ($vmName in $vmList) {
                  # Loop through each group
                  foreach ($groupName in $groupNames) {
                      # Get the Object ID of the group
                      $groupId = (Get-AzureADGroup -SearchString $groupName).ObjectId
              
                      # Create a script block to add the nested group to the group
                      $scriptBlock = @"
                      try {
                          # Check if AzureAD module is installed
                          if (-not (Get-Module -ListAvailable -Name AzureAD)) {
                              # Install AzureAD module
                              Install-Module -Name AzureAD -Force -AllowClobber
                          }
              
                          # Add nested group to group
                          Add-AzureADGroupMember -ObjectId $groupId -RefObjectId $nestedGroupId
                      }
                      catch {
                          Write-Error "Failed to add nested group to group $groupName on server $vmName"
                          exit 1
                      }
              "@ 
                      # Run the script on the VM
                      Invoke-AzVMRunCommand -ResourceGroupName $resourceGroupName -VMName $vmName -CommandId 'RunPowerShellScript' -ScriptString $scriptBlock
                  }
              }
            
            
            
      
      - name: 🔨🔑🔐😎🔓🚪🏡 Run PowerShell scripts Add Admin_SecurityGroups for vms
        if: false
        uses: azure/powershell@v2
        with:
          azPSVersion: latest
          inlineScript: |           
            $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" # Replace with your resource group name
            $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }
            
            foreach ($VM in $vmList) {
              $securityGroupName = "Admin_$VM"
              $domainSecurityGroup = "statoil.net\$securityGroupName"
              
              # Define the script block to add the security group to the local administrators group
              $scriptBlock = @"
              # Install the Active Directory module
              Install-WindowsFeature RSAT-AD-PowerShell

              Install-Module -Name AzureAD -Force -AllowClobber


              # Import the Active Directory module
              Import-Module ActiveDirectory              
  
              # Add the security group to the local administrators group
              Add-LocalGroupMember -Group 'Administrators' -Member '$domainSecurityGroup'
            "@
              
                # Run the script on the VM
                Invoke-AzVMRunCommand -ResourceGroupName "s499-ms-polarion-${{ env.environmentName }}" -VMName $VM -CommandId 'RunPowerShellScript' -ScriptString $scriptBlock
              }
      - name: 🔨🔑🔐😎🔓🚪🏡 Run PowerShell scripts Add AccessIT Admin_SecurityGroups for vms
  
        uses: azure/powershell@v2
        with:
          azPSVersion: latest
          inlineScript: |
            # Define the resource group name
            $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" # Replace with your resource group name
            $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }

            foreach ($VM in $vmList) {
              $securityGroupName = "S499-MSC-Polarion-VMLogin_admins"
              $domainSecurityGroup = "statoil.net\$securityGroupName"
              
              # Define the script block to add the security group to the local administrators group
              $scriptBlock = @"
              # Install the Active Directory module
              Install-WindowsFeature RSAT-AD-PowerShell

              # Import the Active Directory module
              Import-Module ActiveDirectory              
  
              # Add the security group to the local administrators group
              Add-LocalGroupMember -Group 'Administrators' -Member '$domainSecurityGroup'
            "@

              # Run the script on the VM
              Invoke-AzVMRunCommand -ResourceGroupName  $resourceGroupName -VMName $VM -CommandId 'RunPowerShellScript' -ScriptString $scriptBlock
            }
      
      - name: 🍫🍰 🚪🏡 Run PowerShell scripts create shared network folder c:\appl\shared and Add Admin_SecurityGroups for vms
        uses: azure/powershell@v2
        with:
          azPSVersion: latest
          inlineScript: |
            $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" # Replace with your resource group name
            $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }
            
            foreach ($VM in $vmList) {
                $scriptBlock = @"
            
                # Create the directory
                try {
                    New-Item -ItemType Directory -Force -Path "C:\appl\shared"
                } catch {
                    Write-Error "Failed to create directory: $_"
                    exit 1
                }
            
                # Define the ACL
                $Acl = Get-Acl "C:\appl\shared"
            
                # Create a new rule
                $Ar = New-Object  system.security.accesscontrol.filesystemaccessrule("statoil.net\S499-MSC-Polarion-VMLogin_admins","FullControl","Allow")
            
                # Apply the rule to the ACL
                $Acl.SetAccessRule($Ar)
            
                # Apply the ACL to the folder
                try {
                    Set-Acl "C:\appl\shared" $Acl
                } catch {
                    Write-Error "Failed to set ACL: $_"
                    exit 1
                }
            
                # Share the folder
                try {
                    New-SmbShare -Name "SharedFolder" -Path "C:\appl\shared" -FullAccess "statoil.net\S499-MSC-Polarion-VMLogin_admins"
                } catch {
                    Write-Error "Failed to share folder: $_"
                    exit 1
                }
            
            "@
            
            # Run the script on the VM
            try {
                Invoke-AzVMRunCommand -ResourceGroupName $resourceGroupName -VMName $VM -CommandId 'RunPowerShellScript' -ScriptString $scriptBlock
            } catch {
                Write-Error "Failed to run command on VM: $_"
            }
            }    

