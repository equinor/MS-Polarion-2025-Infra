            }

      
      - name: 🔨🔑🔐😎🔓🚪🏡 Run PowerShell scripts create shared network folder c:\appl\shared and Add Admin_SecurityGroups for vms
        
        uses: azure/powershell@v2
        with:
          azPSVersion: latest
          inlineScript: |
            $resourceGroupName = "${{ env.SubscriptionPrefix }}-${{ env.resourceGroupName }}-${{ env.environmentName }}" # Replace with your resource group name
            $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }
            
            foreach ($VM in $vmList) {
                $scriptBlock = @"            
                # Create the directory
                try {
                    New-Item -ItemType Directory -Force -Path "C:\appl\shared"
                } catch {
                    Write-Error "Failed to create directory: $_"
                    exit 1
                }
            
                # Define the ACL
                $Acl = Get-Acl "C:\appl\shared"
            
                # Create a new rule
                $Ar = New-Object  system.security.accesscontrol.filesystemaccessrule("statoil.net\S499-MSC-Polarion-VMLogin_admins","FullControl","Allow")
            
                # Apply the rule to the ACL
                $Acl.SetAccessRule($Ar)
            
                # Apply the ACL to the folder
                try {
                    Set-Acl "C:\appl\shared" $Acl
                } catch {
                    Write-Error "Failed to set ACL: $_"
                    exit 1
                }
            
                # Share the folder
                try {
                    New-SmbShare -Name "SharedFolder" -Path "C:\appl\shared" -FullAccess "statoil.net\S499-MSC-Polarion-VMLogin_admins"
                } catch {
                    Write-Error "Failed to share folder: $_"
                    exit 1
                }            
            "@
            
            # Run the script on the VM
            try {
                Invoke-AzVMRunCommand -ResourceGroupName $resourceGroupName -VMName $VM -CommandId 'RunPowerShellScript' -ScriptString $scriptBlock
            } catch {
                Write-Error "Failed to run command on VM: $_"
            }
            }
          


      - name: Run PowerShell scripts to Copy Content from Blob${{ env.environmentName }} on Azure VMs
        if: false
        uses: azure/powershell@v2
        with:
          azPSVersion: latest
          inlineScript: |
            $SubscriptionPrefix = "${{ env.SubscriptionPrefix }}"
            $ResourceGroupName = "${{ env.resourceGroupName }}"
            $EnvironmentName = "${{ env.environmentName }}"
            $resourceGroupName = "$SubscriptionPrefix-$ResourceGroupName-$EnvironmentName"
            $vmList = Get-AzVM -ResourceGroupName $resourceGroupName | ForEach-Object { $_.Name }
            foreach ($VM in $vmList) {
              # Define the URL of your blob storage
              $blobUrl = "polarion$EnvironmentName.blob.core.windows.net/polarionblob$EnvironmentName"
              # Define the local path where the blob will be downloaded
              $filePath = "C:\path\to\file"
              # Define the command to download the blob using AzCopy
              $command = "& 'C:\Program Files\AzCopy\azcopy.exe' copy '$blobUrl' '$filePath'"
              # Run the command on the VM
              Invoke-AzVMRunCommand -ResourceGroupName $resourceGroupName -VMName $VM -CommandId 'RunPowerShellScript' -ScriptString $command
            }

